# ═══════════════════════════════════════════════════════════════
#  TRADING BOT ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your actual credentials
#  ⚠️ NEVER commit .env to Git!
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────
#  ANGEL ONE API CREDENTIALS
#  Get from: https://smartapi.angelbroking.com/
# ─────────────────────────────────────────
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ─────────────────────────────────────────
#  TELEGRAM BOT
#  1. Message @BotFather → /newbot
#  2. Message @userinfobot → get your chat ID
# ─────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=987654321

# ─────────────────────────────────────────
#  LLM AI AGENTS (Target API: OpenAI, Deepseek, etc.)
# ─────────────────────────────────────────
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# ─────────────────────────────────────────
#  INSTRUCTIONS
# ─────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your real credentials
# 3. Verify .env is in .gitignore
# 4. Test: python -c "import config"
